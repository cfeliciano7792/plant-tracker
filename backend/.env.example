# PostgreSQL connection string (async driver)
DATABASE_URL=postgresql+asyncpg://plant_tracker:changeme@localhost:5432/plant_tracker_dev

# Free API key from https://perenual.com/api-key
PERENUAL_API_KEY=

# Free tier only grants species/details for ids 1-3000 (confirmed live); used
# by app/scripts/sync_perenual_catalog.py to know how many list pages to index.
PERENUAL_FREE_TIER_MAX_PAGE=100

# Free API token from https://trefle.io (taxonomy-only fallback, no care data)
TREFLE_API_KEY=

# Random secret used to sign session cookies — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=

# Shared code family members enter to self-register a new account
FAMILY_INVITE_CODE=

ENVIRONMENT=development
